{
  "compilerOptions": {
    "target": "ESNext", // More modern than es6
    "lib": ["dom", "dom.iterable", "esnext"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true, // Often useful
    "isolatedModules": true,  // Recommended for Vite
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": ["src", "vite.config.ts"], // Include vite.config.ts as it might use aliases
  "references": [{ "path": "./tsconfig.node.json" }] // Vite specific for plugin/config files
}
